  <style>
    @page { size: A4; margin: 2cm; }
    body {
      font-family: "Noto Serif", "DejaVu Serif", Georgia, serif;
      font-size: 11pt;
      line-height: 1.55;
      color: #111;
      margin: 0;
    }
    h1, h2, h3 { font-family: "Noto Sans", "DejaVu Sans", sans-serif; }
    h1 { font-size: 18pt; margin: 0 0 0.4cm 0; }
    h2 { font-size: 13pt; margin: 1cm 0 0.3cm 0; }
    .meta { color: #555; font-size: 10pt; margin-bottom: 0.6cm; }
    p { margin: 0 0 0.4em 0; }
    ol { padding-left: 1.5em; }
    ol li { margin-bottom: 0.4em; }
    .bank-block {
      background: #f5f5f5;
      padding: 0.4cm 0.6cm;
      border-radius: 4px;
      margin: 0.4cm 0;
      font-family: "Noto Sans", "DejaVu Sans", sans-serif;
      font-size: 10.5pt;
    }
    .bank-block dt {
      float: left;
      width: 130px;
      font-weight: 600;
      color: #333;
    }
    .bank-block dd { margin: 0 0 0.2em 130px; }
    .schedule {
      width: 100%;
      border-collapse: collapse;
      margin: 0.4cm 0;
      font-family: "Noto Sans", "DejaVu Sans", sans-serif;
      font-size: 10.5pt;
    }
    .schedule th, .schedule td {
      border: 1px solid #bbb;
      padding: 6px 10px;
      text-align: left;
    }
    .schedule th { background: #f5f5f5; font-weight: 600; }
    .signatures { margin-top: 1.4cm; page-break-inside: avoid; }
    .signatures .sig-row {
      display: flex;
      align-items: flex-end;
      margin-bottom: 0.8cm;
    }
    .signatures .sig-label {
      width: 6cm;
      font-weight: 600;
      font-family: "Noto Sans", "DejaVu Sans", sans-serif;
    }
